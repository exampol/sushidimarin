@using BlazorApp.Data
<ModalEditOrder @ref="EditOrder" OnOrderEdited="ForwardOrderEdited"></ModalEditOrder>

<div class="modal @ModalClass" tabindex="-1" role="dialog" style="display:@ModalDisplay">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">📋 Dettagli — @item</h5>
                <button type="button" class="close" aria-label="Close" @onclick="() => Close()">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <table class="order-table" style="width:100%;">
                    <thead>
                        <tr>
                            <th>@columnName</th>
                            <th style="text-align:center; width:60px;">Qty</th>
                            @if (showEdit) { <th style="width:44px;"></th> }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < details.Count; i++) {
                            string owner = details.ElementAt(i).Key;
                            int qty = details[owner];
                            <tr>
                                <td>@owner</td>
                                <td class="qty">@qty</td>
                                @if (showEdit) {
                                    <td class="action">
                                        @if (owner == name) {
                                            <button class="edit-btn" @onclick="() => { if (!bReadOnly) EditOrder?.Open(item); }" title="Modifica">
                                                <img src="icons8-edit.svg" style="width:16px;height:16px;" />
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="modal-footer" style="justify-content:flex-end;">
                <button type="button" class="btn-sushi btn-secondary" @onclick="() => Close()">Chiudi</button>
            </div>
        </div>
    </div>
</div>

@if (ShowBackdrop) {
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public EventCallback<Tuple<string, int, int>> OnOrderEdited { get; set; }

    private ModalEditOrder? EditOrder { get; set; }
    public Guid Guid = Guid.NewGuid();
    public string ModalDisplay = "none;";
    public string ModalClass = "";
    public bool ShowBackdrop = false;

    private string item = "";
    private string name = "";
    private string columnName = "";
    private bool showEdit = true;
    private Dictionary<string, int> details = new Dictionary<string, int>();
    private bool bReadOnly;

    public void Open(string? _item, string? _name, string? _columnName, bool? _showEdit, Dictionary<string, int> _details, bool bReadOnly) {
        ModalDisplay = "block;";
        ModalClass = "Show";
        ShowBackdrop = true;
        item       = _item       ?? "";
        name       = _name       ?? "";
        columnName = _columnName ?? "";
        showEdit   = _showEdit ?? true;
        details    = _details;
        this.bReadOnly = bReadOnly;
        StateHasChanged();
    }

    public async Task Close() {
        ModalDisplay = "none";
        ModalClass   = "";
        ShowBackdrop = false;
        StateHasChanged();
    }

    private async Task ForwardOrderEdited(Tuple<string, int, int> args) {
        await OnOrderEdited.InvokeAsync(args);
    }
}
